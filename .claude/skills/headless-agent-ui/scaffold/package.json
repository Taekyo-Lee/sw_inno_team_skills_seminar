{
  "name": "agent-skill-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "ChatGPT-style web UI for headless LLM CLI tools (opencode, gemini-cli)",
  "scripts": {
    "dev": "concurrently -n ui,api -c cyan,green \"vite\" \"tsx watch server/index.ts\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
